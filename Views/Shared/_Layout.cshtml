<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NEU Management</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentRole = Context.Session.GetString("Role");
    }
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container-fluid px-4">
            <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <div class="bg-primary text-white p-2 rounded-3 me-2 d-flex shadow-sm">
                    <i class="bi bi-grid-1x2-fill fs-5"></i>
                </div>
                <span>EDUFLOW</span>
            </a>

            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
                <i class="bi bi-list fs-2"></i>
            </button>

            <div class="collapse navbar-collapse" id="navContent">
                <ul class="navbar-nav mx-auto bg-light rounded-pill px-3 py-1">
                    <li class="nav-item"><a class="nav-link px-3" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link px-3" asp-controller="HocPhan" asp-action="DanhSach">Học phần</a></li>
                    @if (currentRole == "Admin")
                    {
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="User" asp-action="Index">Quản lý Người dùng</a></li>
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="PhanCong" asp-action="Index">Phân công giảng dạy</a></li>
                    }
                    @if (currentRole == "GiaoVien")
                    {
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="HocPhan" asp-action="MonHocCuaToi">Môn học của tôi</a></li>
                    }
                    <li class="nav-item"><a class="nav-link px-3" asp-controller="Dashboard" asp-action="Index">Báo cáo</a></li>
                </ul>

                <div class="d-flex gap-3 align-items-center">
                    <a class="text-dark text-decoration-none fw-semibold" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                    <a class="btn btn-primary px-4 rounded-pill shadow" asp-controller="Account" asp-action="Logout">
                        <i class="bi bi-box-arrow-right me-1"></i> Thoát
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container" style="padding-top: 120px; padding-bottom: 100px;">
        <main role="main" class="main-content">
            @RenderBody()
        </main>
    </div>

    <footer class="py-5 bg-white border-top shadow-sm mt-auto">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <span class="fw-bold text-primary">EDUFLOW</span> <small class="text-muted ms-2">© 2026 Toàn bộ quyền được bảo lưu.</small>
                </div>
                <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                    <small class="text-muted">Phát triển bởi <b>NEU Team</b></small>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>