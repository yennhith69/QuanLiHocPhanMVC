@model List<QuanLyHocPhanMVC.Models.HocPhan>

@{
    ViewData["Title"] = "Danh sách học phần";
}

<div class="custom-card shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Học phần</h2>
            <p class="text-muted small">Quản lý danh sách các học phần trong hệ thống</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/HocPhan/ExportCsv?search=@(ViewBag.Search ?? string.Empty)" class="btn btn-light border d-flex align-items-center gap-2">
                <i class="bi bi-download"></i> Xuất CSV
            </a>
            <a href="/HocPhan/Create" class="btn btn-primary d-flex align-items-center gap-2">
                <i class="bi bi-plus-lg"></i> Thêm mới
            </a>
        </div>
    </div>

    <form method="get" class="mb-4">
        <div class="input-group" style="max-width: 400px;">
            <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px;">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" name="search" class="form-control border-start-0 ps-0"
                   placeholder="Tìm kiếm học phần..." style="border-radius: 0 12px 12px 0;">
            <button class="btn btn-dark ms-2 rounded-3 px-4" type="submit">Tìm</button>
        </div>
    </form>

    @if (Model.Count == 0)
    {
        <div class="alert alert-light border mb-4">Không tìm thấy học phần phù hợp.</div>
    }

    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th class="ps-4">Mã học phần</th>
                    <th>Tên học phần</th>
                    <th class="text-center">Số tín chỉ</th>
                    <th>Mô tả</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var hp in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <span class="badge bg-light text-dark border px-3 py-2 fw-semibold">
                                @hp.MaHocPhan
                            </span>
                        </td>
                        <td>
                            <div class="fw-bold">@hp.TenHocPhan</div>
                        </td>
                        <td class="text-center">
                            <span class="text-primary fw-bold">@hp.SoTinChi</span>
                        </td>
                        <td>
                            <small class="text-muted text-truncate d-inline-block" style="max-width: 200px;">
                                @hp.MoTa
                            </small>
                        </td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a href="/HocPhan/ChiTiet/@hp.IDHocPhan" class="btn btn-light btn-sm rounded-3 shadow-sm">
                                    <i class="bi bi-eye text-primary"></i>
                                </a>
                                <a href="/HocPhan/Edit/@hp.IDHocPhan" class="btn btn-light btn-sm rounded-3 shadow-sm">
                                    <i class="bi bi-pencil-square text-success"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-center mt-4">
        <nav aria-label="Page navigation">
            <ul class="pagination gap-2">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                        <a class="page-link border-0 rounded-3 shadow-sm @(i == ViewBag.Page ? "btn-primary" : "text-dark bg-white")"
                           href="/HocPhan/DanhSach?page=@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>