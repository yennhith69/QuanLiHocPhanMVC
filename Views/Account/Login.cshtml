@model QuanLyHocPhanMVC.Models.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập hệ thống";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-5 col-lg-4">
        <div class="custom-card shadow-lg border-0" style="padding: 3rem 2.5rem;">
            <div class="text-center mb-4">
                <div class="bg-primary text-white d-inline-flex align-items-center justify-content-center rounded-circle mb-3 shadow"
                     style="width: 70px; height: 70px; background: var(--primary-gradient) !important;">
                    <i class="bi bi-shield-lock-fill fs-2"></i>
                </div>
                <h3 class="fw-800 text-dark">Welcome Back</h3>
                <p class="text-muted small">Vui lòng đăng nhập để quản lý học phần</p>
            </div>

            <form method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                <div class="mb-3">
                    <label class="form-label small fw-bold text-uppercase text-muted">Tên đăng nhập</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0" style="border-radius: 12px 0 0 12px;">
                            <i class="bi bi-person text-muted"></i>
                        </span>
                        <input asp-for="Username" class="form-control border-start-0 ps-0"
                               placeholder="admin" style="border-radius: 0 12px 12px 0;" />
                    </div>
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold text-uppercase text-muted">Mật khẩu</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0" style="border-radius: 12px 0 0 12px;">
                            <i class="bi bi-key text-muted"></i>
                        </span>
                        <input asp-for="Password" type="password" class="form-control border-start-0 ps-0"
                               placeholder="••••••••" style="border-radius: 0 12px 12px 0;" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger border-0 rounded-3 py-2 small d-flex align-items-center mb-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        @ViewBag.Error
                    </div>
                }

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary py-3 fw-bold shadow">
                        Đăng nhập <i class="bi bi-arrow-right-short ms-1"></i>
                    </button>
                </div>

                <div class="text-center mt-4">
                    <a href="#" class="text-decoration-none small text-muted">Quên mật khẩu?</a>
                </div>
            </form>
        </div>

        <p class="text-center mt-4 text-muted small">
            Bạn chưa có tài khoản? <a href="#" class="text-primary fw-bold text-decoration-none">Liên hệ Admin</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}