@model List<QuanLyHocPhanMVC.Models.NguoiDung>

@{
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="custom-card shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Danh sách Người dùng</h2>
            <p class="text-muted small mb-0">Quản lý tài khoản và phân quyền người dùng trong hệ thống</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/PhanCong/Index" class="btn btn-light border">Phân công giảng dạy</a>
            <a href="/User/Create" class="btn btn-primary">Thêm người dùng mới</a>
        </div>
    </div>

    <form method="get" class="mb-4">
        <div class="input-group" style="max-width: 420px;">
            <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px;">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" name="search" class="form-control border-start-0 ps-0" placeholder="Tìm theo Username hoặc Role..." value="@ViewBag.Search" style="border-radius: 0 12px 12px 0;" />
            <button type="submit" class="btn btn-dark ms-2 rounded-3 px-4">Tìm kiếm</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th class="ps-4">ID</th>
                    <th>Username</th>
                    <th>Password</th>
                    <th>Role</th>
                    <th class="text-end pe-4">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="ps-4">@user.ID</td>
                        <td class="fw-semibold">@user.Username</td>
                        <td><span class="text-muted">••••••••</span></td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge bg-danger">@user.Role</span>
                            }
                            else if (user.Role == "GiaoVien")
                            {
                                <span class="badge bg-primary">@user.Role</span>
                            }
                            else
                            {
                                <span class="badge bg-success">@user.Role</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a href="/User/Edit/@user.ID" class="btn btn-light btn-sm rounded-3 shadow-sm">
                                    <i class="bi bi-pencil-square text-success"></i>
                                </a>
                                <a href="/User/Delete/@user.ID" class="btn btn-light btn-sm rounded-3 shadow-sm" onclick="return confirm('Bạn có chắc muốn xóa người dùng này không?')">
                                    <i class="bi bi-trash text-danger"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-center mt-4">
        <nav aria-label="Page navigation">
            <ul class="pagination gap-2">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                        <a class="page-link border-0 rounded-3 shadow-sm @(i == ViewBag.Page ? "btn-primary" : "text-dark bg-white")" href="/User/Index?page=@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>
